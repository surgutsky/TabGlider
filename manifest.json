{
  "manifest_version": 3,
  "name": "TabGlider",
  "version": "0.1.0",
  "description": "Tab profile manager — save and restore named tab workspaces",
  "permissions": ["tabs", "tabGroups", "storage", "sidePanel", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "TabGlider",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/quickswitcher/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "open-quick-switcher": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Open profile quick switcher"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/switching/index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
